           scan_script: "vm_scan.pl ius.flt shell.flt" ;
	   count : 1;
      };

      test test7 {
      	   run_script: "cd $ENV(PWD) ; xrun -f run_vd.f +UVM_TESTNAME=read_miss_icache -define TEST7" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
	   count : 1;
      };

      test test8 {
      	   run_script: "cd $ENV(PWD) ; xrun -f run_vd.f +UVM_TESTNAME=read_miss_icache -define TEST8" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
	   count : 1;
