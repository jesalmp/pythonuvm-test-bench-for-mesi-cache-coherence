      test exhaustive_interface_test {
      	   run_script: "cd $ENV(PWD) ; xrun -f run_vd.f +UVM_TESTNAME=exhaustive_interface_test.sv" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
