         run_script: "cd $ENV(PWD) ; xrun -f run_vm.f +UVM_TESTNAME=icache_eviction_test" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
   count : 1;
      };

      test lru_blk3_bias_test {
         run_script: "cd $ENV(PWD) ; xrun -f run_vm.f +UVM_TESTNAME=lru_blk3_bias_test" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
   count : 1;
      };

