session multi_core_regress
{
top_dir : $ENV(PWD)/regression/ ;
pre_session_script : <text> echo "pre_session_script" </text>;
};


group all_test {

      scan_script: "vm_scan.pl ius.flt shell.flt" ;
      count : 1;
      pre_commands: "";
      timeout: 13000000;
      sv_seed: random;

      test read_miss_icache {
         run_script: "cd $ENV(PWD) ; xrun -f run_vm.f +UVM_TESTNAME=read_miss_icache" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
   count : 1;
      };

      test shared_snoop_invalidate_test {
         run_script: "cd $ENV(PWD) ; xrun -f run_vm.f +UVM_TESTNAME=shared_snoop_invalidate_test" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
   count : 1;
      };

      test snoop_mesi_update_test {
         run_script: "cd $ENV(PWD) ; xrun -f run_vm.f +UVM_TESTNAME=snoop_mesi_update_test" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
   count : 1;
      };

      test lru_eviction_test {
         run_script: "cd $ENV(PWD) ; xrun -f run_vm.f +UVM_TESTNAME=lru_eviction_test" ;
           scan_script: "vm_scan.pl ius.flt shell.flt" ;
   count : 1;
      };

      test dirty_replacement_read_test {
         run_script: "cd $ENV(PWD) ; xrun -f run_vm.f +UVM_TESTNAME=dirty_replacement_read_test" ;
